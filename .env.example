# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_TITLE=Computer Shop
VITE_APP_DESCRIPTION=Computer Shop - Laptops, Gaming PCs, Components & Accessories

# Feature Flags
VITE_ENABLE_DEVTOOLS=true
VITE_ENABLE_ANALYTICS=false

# Environment
VITE_ENV=development
VITE_DEBUG=true

# Social Links
VITE_FACEBOOK_URL=https://facebook.com
VITE_TWITTER_URL=https://twitter.com
VITE_INSTAGRAM_URL=https://instagram.com

# Contact Info
VITE_SUPPORT_EMAIL=support@computershop.test
VITE_SUPPORT_PHONE=+855 12 345 678

# Pagination
VITE_DEFAULT_PAGE_SIZE=12
VITE_MAX_PAGE_SIZE=50

# Image Configuration
VITE_IMAGE_QUALITY=80
VITE_IMAGE_MAX_WIDTH=1200
